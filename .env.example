# Copy this file to .env and fill in whichever keys you have.
# You don't need all of them — see README.md "Setup" for where to get each one free.

# Model under test (recommended primary — free tier, frontier-class quality)
GEMINI_API_KEY=

# Judge model / second model to compare (free tier, very fast open-weight models)
GROQ_API_KEY=

# Fronts 25+ free open-weight models (Llama, DeepSeek, Qwen, Gemma, GPT-OSS, etc.)
OPENROUTER_API_KEY=

# Fine-grained PAT with "Models" read-only scope — routes gpt-4o / chatgpt-4 here
GITHUB_TOKEN=

# Optional — only used if explicitly selected in the dashboard's advanced options
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
